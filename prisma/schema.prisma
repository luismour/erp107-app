generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Youth {
  id        String   @id @default(uuid())
  name      String
  age       Int
  branch    String
  createdAt DateTime @default(now())

  guardians Guardian[]
  fees      Fee[]
  funds       FundTransaction[]
}

model Guardian {
  id        String   @id @default(uuid())
  name      String
  phone     String
  createdAt DateTime @default(now())

  youthId String
  youth   Youth @relation(fields: [youthId], references: [id], onDelete: Cascade)
}

model Fee {
  id        String   @id @default(uuid())
  month     Int
  year      Int
  amount    Float
  status    String
  dueDate   DateTime
  createdAt DateTime @default(now())

  youthId String
  youth   Youth @relation(fields: [youthId], references: [id], onDelete: Cascade)
}

model FundTransaction {
  id          String   @id @default(uuid())
  youthId     String
  youth       Youth    @relation(fields: [youthId], references: [id], onDelete: Cascade)
  amount      Float
  description String   
  type        String   @default("credit")
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  date        DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   
  condition   String   @default("BOM") 
  location    String?  
  owner       String?  
  quantity    Int      @default(1)
  borrowed    Int      @default(0) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}